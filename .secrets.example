# C&C Server Secrets — copy to .secrets and fill in your values
# .secrets is gitignored and never committed.

# Root password for first-boot SSH access (used by combustion/script)
# Default is "changeme-on-first-login" if not set.
ROOT_PASSWORD="CHANGEME"

# Tailscale pre-auth key (generate at https://login.tailscale.com/admin/settings/keys)
# These expire after 90 days by default — regenerate as needed.
TS_AUTH_KEY="tskey-auth-CHANGEME"

# Anthropic API key — leave empty to use Ollama only
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
